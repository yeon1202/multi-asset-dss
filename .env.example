# API 키 템플릿 — 실제 키는 .env에 저장하고 절대 커밋하지 않습니다.
# Phase 1에서는 사용하지 않지만 향후 Phase를 위해 미리 정의해둡니다.

# Phase 2+: 한국 금감원 DART (재무제표·공시)
# 발급: https://opendart.fss.or.kr
DART_API_KEY=

# Phase 3+: 한국은행 ECOS (거시 데이터)
# 발급: https://ecos.bok.or.kr/api
ECOS_API_KEY=

# Phase 3+: FRED (미국 거시 데이터)
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Phase 6+: Anthropic (LLM 정성 분석)
# 발급: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Phase 2+ 선택: 한국투자증권 KIS (수급·호가)
KIS_APP_KEY=
KIS_APP_SECRET=
